# Copy this file to Streamlit Community Cloud secrets, not to .streamlit/secrets.toml in Git.
# Streamlit Cloud: App settings -> Secrets

SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_ANON_KEY = "your-supabase-anon-key"

# Public.com server-side credential. Never commit a real value.
PUBLIC_API_SECRET = "your-public-secret-key"
# Optional when your key can access multiple Public accounts.
# PUBLIC_ACCOUNT_NUMBER = "your-public-account-number"

# Optional external market data keys. Keep calls server-side in Python modules.
# MARKET_DATA_API_KEY = "your-api-key"

